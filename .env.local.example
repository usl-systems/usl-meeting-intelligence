# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# Processing limits
MAX_TRANSCRIPT_CHARS=120000
CHUNK_TOKEN_TARGET=2000

# Public app config
NEXT_PUBLIC_APP_NAME=Meeting Intelligence
