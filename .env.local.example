# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Processing limits
MAX_TRANSCRIPT_CHARS=120000
CHUNK_TOKEN_TARGET=2000

# Public app config
NEXT_PUBLIC_APP_NAME=Meeting Intelligence
NEXT_PUBLIC_APP_DESCRIPTION=An AI-powered meeting assistant that helps you capture, summarize, and analyze
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Make.com webhooks (optional — buttons appear only when configured)
NEXT_PUBLIC_MAKE_SHAREPOINT_WEBHOOK_URL=
NEXT_PUBLIC_MAKE_TEAMS_WEBHOOK_URL=
